# ─── Azure AI Foundry ────────────────────────────────────────────────────────
# Your project endpoint — found in AI Foundry portal → Project → Overview
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://<your-hub>.services.ai.azure.com/api/projects/<your-project>

# Name of a GPT-4o (or GPT-4o-mini) deployment in your Foundry project
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# ─── Azure OpenAI (for RAG embeddings) ──────────────────────────────────────
# The Azure OpenAI resource endpoint (connected to your Foundry project or standalone)
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/

# API key for the Azure OpenAI resource
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>

# Name of your text-embedding-ada-002 (or text-embedding-3-small) deployment
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ─── Azure AI Search ────────────────────────────────────────────────────────
# The Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Admin API key (found in Azure Portal → Search service → Keys)
AZURE_SEARCH_API_KEY=<your-search-admin-key>

# Index name — must match what create_index.py creates
AZURE_SEARCH_INDEX_NAME=return-policies

# ─── Azure PostgreSQL ────────────────────────────────────────────────────────
# Flexible Server hostname (shown in Azure Portal → PostgreSQL → Overview)
POSTGRES_HOST=<your-server>.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=shopease
POSTGRES_USER=<your-admin-username>
POSTGRES_PASSWORD=<your-password>
